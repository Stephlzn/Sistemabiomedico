@model SistemaBiomedico.Models.Ticket
<style>
    .card-custom {
        background: white;
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
        padding: 30px;
    }

    .page-title {
        color: #1B4965;
        font-weight: 700;
        margin-bottom: 25px;
    }

    .form-label {
        font-weight: 600;
        color: #1B4965;
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        border: 1px solid #d6e4ea;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #1F6F8B;
            box-shadow: 0 0 0 .2rem rgba(31,111,139,.15);
        }

    .btn-save {
        background: #1F6F8B;
        border: none;
        border-radius: 10px;
        padding: 10px 25px;
        font-weight: 600;
        color: white;
    }

        .btn-save:hover {
            background: #17586D;
            color: white;
        }

    .btn-back {
        border-radius: 10px;
        padding: 10px 25px;
        font-weight: 600;
    }
</style>
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card-custom">
                <h2 class="page-title">
                    🚨 Reportar Incidencia
                </h2>
                <form asp-controller="Ticket"
                      asp-action="Nuevo"
                      method="post"
                      autocomplete="off">
                    <div class="mb-4">
                        <label class="form-label">
                            Equipo Biomédico
                        </label>
                        <select class="form-select"
                                asp-for="IdEquipo"
                                asp-items="ViewBag.Equipos">
                            <option value="">
                                Seleccione un equipo
                            </option>
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">
                            Descripción de la Incidencia
                        </label>
                        <textarea class="form-control"
                                  asp-for="Descripcion"
                                  rows="5"
                                  placeholder="Describa el problema encontrado en el equipo..."
                                  required>
                        </textarea>
                    </div>
                    <div class="alert alert-info mt-3">

                        <strong>Ejemplo de reporte:</strong>

                        <br /><br />

                        Equipo: Monitor de Signos Vitales

                        <br />

                        Área: UCI

                        <br />

                        Problema detectado: La pantalla presenta parpadeos constantes y deja de mostrar los signos vitales después de algunos minutos de uso.

                        <br />

                        Impacto: El personal no puede monitorear adecuadamente a los pacientes.

                        <br />

                        Fecha/Hora aproximada: 15/06/2026 - 10:30 a.m.

                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-save"
                                type="submit">
                            Enviar Ticket
                        </button>
                        <a asp-controller="Login"
                           asp-action="Operativo"
                           class="btn btn-danger btn-back">
                            Volver
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>