@model List<SistemaBiomedico.Models.Areas>
<style>
    .page-title {
        color: #1B4965;
        font-weight: 700;
    }

    .card-custom {
        background: white;
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
        padding: 25px;
    }

    .btn-new {
        background: #1F6F8B;
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
    }

        .btn-new:hover {
            background: #17586D;
        }

    .table {
        margin-top: 20px;
    }

        .table thead {
            background: #1F6F8B;
            color: white;
        }

        .table th {
            text-align: center;
            vertical-align: middle;
        }

        .table td {
            vertical-align: middle;
        }

    .btn-edit {
        background: #2E86AB;
        color: white;
        border: none;
        border-radius: 8px;
    }

        .btn-edit:hover {
            background: #247194;
            color: white;
        }

    .btn-delete {
        border-radius: 8px;
    }
</style>
<div class="container mt-4">
    <div class="card-custom">
        <div class="d-flex justify-content-between align-items-center">

            <h2 class="page-title">
                🏢 Gestión de Áreas
            </h2>
            <a asp-controller="Area"
               asp-action="Nuevo"
               class="btn btn-new text-white">
                + Nueva Área
            </a>
        </div>
        <table class="table table-hover table-bordered">

            <thead>
                <tr>
                    <th style="width:120px">ID</th>
                    <th>Nombre del Área</th>
                    <th style="width:220px">Opciones</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td class="text-center">
                            @item.IdAreas
                        </td>

                        <td>
                            @item.NombreArea
                        </td>

                        <td class="text-center">

                            <a asp-controller="Area"
                               asp-action="Editar"
                               asp-route-id="@item.IdAreas"
                               class="btn btn-edit btn-sm">
                                Editar
                            </a>

                            <a asp-controller="Area"
                               asp-action="Eliminar"
                               asp-route-id="@item.IdAreas"
                               class="btn btn-danger btn-sm btn-delete"
                               onclick="return confirmar()">
                                Eliminar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@section Scripts {
    <script>
        function confirmar() {
            return confirm("¿Está seguro que desea eliminar esta área?");
        }

    </script>
}
