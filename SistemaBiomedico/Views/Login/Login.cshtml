@model SistemaBiomedico.ViewModels.LoginVM;
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Sistema BioMed</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
            body {
                background: linear-gradient(135deg, #dff4ff, #ffffff);
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                font-family: 'Segoe UI', sans-serif;
            }
            .login-container {
                width: 950px;
                background: white;
                border-radius: 25px;
                overflow: hidden;
                box-shadow: 0 15px 35px rgba(0,0,0,.10);
            }
            .left-panel {
                background: linear-gradient(135deg,#1B4965,#2E86AB);
                color: white;
                padding: 50px;
            }
            .hospital-icon {
                font-size: 70px;
                margin-bottom: 20px;
            }
            .left-panel h1 {
                font-weight: 700;
                margin-bottom: 15px;
            }
            .left-panel p {
                font-size: 16px;
                opacity: .95;
            }
            .right-panel {
                padding: 50px;
            }
            .title-login {
                color: #1B4965;
                font-weight: 700;
            }
            .subtitle {
                color: #7f8c8d;
                margin-bottom: 30px;
            }
            .form-control {
                border-radius: 12px;
                height: 50px;
                border: 1px solid #d6e4ea;
            }
            .form-control:focus {
                border-color: #2E86AB;
                box-shadow: 0 0 0 .2rem rgba(46,134,171,.15);
            }
            .btn-login {
                height: 50px;
                border: none;
                border-radius: 12px;
                background: #1B4965;
                color: white;
                font-weight: 600;
                transition: .3s;
            }
            .btn-login:hover {
                background: #1B4965;
                transform: translateY(-2px);
            }
            .register-link {
                color: #1B4965;
                font-weight: 700;
                text-decoration: none;
                font-weight: 600;
            }
            .register-link:hover {
                text-decoration: underline;
            }
            .logo-circle {
                width: 90px;
                height: 90px;
                border-radius: 50%;
                background: rgba(255,255,255,.20);
                display: flex;
                justify-content: center;
                align-items: center;
                margin-bottom: 25px;
            }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="row g-0">
            <div class="col-md-6 left-panel d-flex flex-column justify-content-center">
                <div class="logo-circle">
                    <div class="hospital-icon">🏥</div>
                </div>
                <h1>BioCare System</h1>
                <p>
                    Sistema de Gestión de Equipos Biomédicos
                </p>
                <p>
                    Registro de incidencias, seguimiento técnico y control de equipos hospitalarios.
                </p>
            </div>
            <div class="col-md-6 right-panel">
                <h2 class="title-login">
                    Bienvenido
                </h2>
                <p class="subtitle">
                    Inicia sesión para continuar
                </p>
                <form asp-controller="Login" asp-action="Login" method="post" autocomplete="off">

                    <input class="form-control mb-3"
                           type="email"
                           placeholder="Correo electrónico"
                           required
                           asp-for="Email" />
                    <input class="form-control mb-3"
                           type="password"
                           placeholder="Contraseña"
                           required
                           asp-for="Password" />
                    <div class="d-grid mb-3">
                        <button class="btn-login" type="submit">
                            Iniciar Sesión
                        </button>
                    </div>
                </form>
                @if (ViewData["Mensaje"] != null)
                {
                    <div class="alert alert-danger">
                        @ViewData["Mensaje"]
                    </div>
                }
                <div class="text-center mt-4">
                    <small class="text-muted">
                        Si necesita acceso al sistema, contacte con el administrador.
                    </small>
                </div>
            </div>
        </div>
    </div>
</body>
</html>